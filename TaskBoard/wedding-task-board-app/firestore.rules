rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBoardOwner(boardId) {
      return signedIn()
        && get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId == request.auth.uid;
    }

    function isBoardMember(boardId) {
      return signedIn()
        && (
          get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds
        );
    }

    function isAcceptingOwnInvite() {
      return signedIn()
        && request.auth.token.email in resource.data.memberEmails
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'memberIds',
          'memberEmails',
          'visibility',
          'updatedAt'
        ]);
    }

    function isTouchingBoardTimestamp(boardId) {
      return isBoardMember(boardId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt']);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /boards/{boardId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.memberIds);
      allow update: if isBoardOwner(boardId) || isAcceptingOwnInvite() || isTouchingBoardTimestamp(boardId);
      allow delete: if isBoardOwner(boardId);

      match /tasks/{taskId} {
        allow read, create, update: if isBoardMember(boardId);
        allow delete: if isBoardOwner(boardId);
      }

      match /settings/{settingId} {
        allow read: if isBoardMember(boardId);
        allow create, update, delete: if isBoardOwner(boardId);
      }
    }

    match /invites/{inviteId} {
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read, update: if signedIn()
        && (resource.data.email == request.auth.token.email || resource.data.createdBy == request.auth.uid);
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
